# Server Configuration
PORT=3000
NODE_ENV=development

# MongoDB Configuration
MONGODB_URI=mongodb+srv://backend_user:PASSWORD@cluster.mongodb.net/iot_dashboard_db

# MQTT Broker Configuration expected for HiveMQ Cloud
# Backend user must not be shared with ESP32 devices
MQTT_HOST=dd2850a79b434dd99693c51b23d03f8d.s1.eu.hivemq.cloud
MQTT_PORT=8883
MQTT_USERNAME=backend_user_01
MQTT_PASSWORD=YOUR_BACKEND_PASSWORD
